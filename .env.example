DATA_SOURCE_NAME="host=localhost user=postgres password=postgres dbname=geojson port=5432 sslmode=disable"
PORT=8080
CORS_ORIGINS="*"
REDIS_URL="localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0

# S3 Configuration
S3_BUCKET="your-bucket-name"
S3_REGION="us-east-1"
S3_BASE_URL="https://your-bucket-name.s3.amazonaws.com"

# RabbitMQ Configuration
RABBITMQ_URL="amqp://guest:guest@localhost:5672/"
RABBITMQ_EXCHANGE="optimization"
RABBITMQ_ROUTING_KEY="3d.optimize"

# 3D Optimization
OPTIMIZATION_WEBHOOK_URL="https://api.example.com/webhook/optimization"
